@model Ejercicio_1_LAB_3.Models.Employee

@{
    ViewData["Title"] = "Detalles empleado";
}

<h1>Detalles</h1>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.FirstName</dd>

    <dt class="col-sm-2">Apellido</dt>
    <dd class="col-sm-10">@Model.LastName</dd>

    <dt class="col-sm-2">Puesto</dt>
    <dd class="col-sm-10">@Model.Position</dd>

    <dt class="col-sm-2">Contratación</dt>
    <dd class="col-sm-10">@Model.HireDate.ToShortDateString()</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Volver</a>

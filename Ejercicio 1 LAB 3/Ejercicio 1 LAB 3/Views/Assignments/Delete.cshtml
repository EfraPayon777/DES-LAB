@model Ejercicio_1_LAB_3.Models.Assignment

@{
    ViewData["Title"] = "Eliminar asignación";
}

<h1>Eliminar</h1>

<p>¿Seguro que desea eliminar la asignación de <strong>@Model.Employee?.FirstName @Model.Employee?.LastName</strong> al proyecto <strong>@Model.Project?.Name</strong>?</p>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

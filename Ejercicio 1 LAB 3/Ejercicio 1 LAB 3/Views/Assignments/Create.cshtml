@model Ejercicio_1_LAB_3.Models.Assignment
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Crear asignación";
}

<h1>Crear asignación</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="EmployeeId" class="form-label"></label>
        @Html.DropDownListFor(m => m.EmployeeId, (SelectList)ViewData["EmployeeId"], "-- Seleccione --", new { @class = "form-select", title = "Empleado" })
    </div>
    <div class="mb-3">
        <label asp-for="ProjectId" class="form-label"></label>
        @Html.DropDownListFor(m => m.ProjectId, (SelectList)ViewData["ProjectId"], "-- Seleccione --", new { @class = "form-select", title = "Proyecto" })
    </div>
    <div class="mb-3">
        <label asp-for="AssignedDate" class="form-label">Fecha de asignación</label>
        <input asp-for="AssignedDate" type="date" class="form-control" title="Fecha de asignación" />
        <span asp-validation-for="AssignedDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Role" class="form-label">Rol</label>
        <input asp-for="Role" class="form-control" placeholder="Rol" title="Rol" />
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

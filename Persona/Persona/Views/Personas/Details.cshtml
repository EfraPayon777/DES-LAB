@model PersonaApp.Models.Persona

<h1>Detalles</h1>

<div>
    <h4>Persona</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">DUI</dt>
        <dd class="col-sm-10">@Model.DUI</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Apellido</dt>
        <dd class="col-sm-10">@Model.Apellido</dd>

        <dt class="col-sm-2">Fecha de nacimiento</dt>
        <dd class="col-sm-10">@Model.FechaNacimiento.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">Dirección</dt>
        <dd class="col-sm-10">@Model.Direccion</dd>

        <dt class="col-sm-2">Correo</dt>
        <dd class="col-sm-10">@Model.Email</dd>
    </dl>

    <p>
        <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.DUI">Editar</a>
        <a class="btn btn-link" asp-action="Index">Volver al listado</a>
    </p>
</div>

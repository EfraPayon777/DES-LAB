@model PersonaApp.Models.Persona

<h1>Eliminar Persona</h1>

<h4>¿Está seguro que desea eliminar esta persona?</h4>
<div>
    <dl class="row">
        <dt class="col-sm-2">DUI</dt>
        <dd class="col-sm-10">@Model.DUI</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Apellido</dt>
        <dd class="col-sm-10">@Model.Apellido</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="DUI" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-link">Cancelar</a>
    </form>
</div>
